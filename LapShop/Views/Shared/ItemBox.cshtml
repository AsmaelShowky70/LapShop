@model VwItem

@{
    var isArabic = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
}

<div class="img-wrapper">
    <div class="front">
        <a asp-controller="Items" asp-action="ItemDetails" asp-route-id="@Model.ItemId">
            <img src="~/Uploads/Items/@Model.ImageName"
                 class="img-fluid blur-up lazyload bg-img" alt="@Model.ItemName">
        </a>
    </div>
    <div class="cart-info cart-wrap">
        <a asp-controller="Order" asp-action="AddToCart"
           asp-route-itemId="@Model.ItemId"
           title="@(isArabic ? "إضافة إلى المفضلة" : "Add to wishlist")" tabindex="0">
            <i class="ti-heart" aria-hidden="true"></i>
        </a>
    </div>
    <a asp-controller="Order" asp-action="AddToCart"
       asp-route-itemId="@Model.ItemId" class="add-button">
        @(isArabic ? "أضف إلى السلة" : "add to cart")
    </a>
</div>
<div class="product-detail">
    <div class="rating">
        <i class="fa fa-star"></i> <i class="fa fa-star"></i> <i class="fa fa-star"></i> <i class="fa fa-star"></i> <i class="fa fa-star"></i>
    </div>
    <a asp-controller="Items" asp-action="ItemDetails" asp-route-id="@Model.ItemId">
        <h6>@Model.ItemName</h6>
    </a>
    <h4>@Model.SalesPrice @(isArabic ? "جنيه" : "EGP")</h4>
</div>
